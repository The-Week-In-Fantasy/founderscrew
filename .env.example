# 🚀 FoundersCrew — Env Variables Config Template
# Copy this file to .env and fill in the values, or run 'founderscrew setup'

# --- GITHUB ---
# GitHub Personal Access Token (if not using OAuth device flow)
GITHUB_TOKEN=your_github_token_here
# Target GitHub repository in 'owner/repo' format
FOUNDERSCREW_REPO=owner/repo
# Label that triggers the AI agent flow (defaults to crew:ready)
GITHUB_TRIGGER_LABEL=crew:ready
# Webhook secret shared with GitHub (Settings > Webhooks). Strongly recommended:
# without it, webhook deliveries are not verified and anyone with the URL
# could forge approval comments.
GITHUB_WEBHOOK_SECRET=choose_a_long_random_string

# --- GOOGLE CLOUD & GEMINI ---
# Google API Key for Gemini API (Vertex AI or AI Studio)
GOOGLE_API_KEY=AIzaSy...
# Google Cloud Project ID (if deploying to Cloud Run)
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# --- DISCORD NOTIFICATIONS ---
# Webhook URL for Discord channel notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- THIRD-PARTY CODING LLM APIS (OPTIONAL FALLBACKS) ---
# Anthropic API Key (for Claude Code / Claude API mode)
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI API Key (for Codex / GPT API mode)
OPENAI_API_KEY=sk-proj-...
# xAI API Key (for Grok model tiers)
XAI_API_KEY=xai-...
